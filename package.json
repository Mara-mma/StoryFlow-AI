{
  "name": "storyflow-ai",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,green \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "cd apps/api && npm run start:dev",
    "build": "npm run build -w apps/web",
    "build:api": "cd apps/api && npm run build",
    "install:all": "npm install && cd apps/api && npm install"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
